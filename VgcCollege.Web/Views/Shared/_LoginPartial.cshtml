@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<div class="d-flex align-items-center gap-3">
    @if (SignInManager.IsSignedIn(User))
    {
        <span><i>Hello @User.Identity?.Name!</i></span>
        <span>|</span>

        @if (User.IsInRole("Admin"))
        {
            <a class="as-link" asp-controller="Admin" asp-action="MyProfile">My Profile</a>
        }
        @if (User.IsInRole("Faculty"))
        {
            <a class="as-link" asp-controller="FacultyProfile" asp-action="MyProfile">My Profile</a>
        }
        @if (User.IsInRole("Student"))
        {
            <a class="as-link" asp-controller="StudentProfile" asp-action="MyProfile">My Profile</a>
        }

        <span>|</span>
        <form method="post" asp-area="Identity" asp-page="/Account/Logout" class="m-0">
            <button type="submit" class="as-link">Logout</button>
        </form>
    }
    else
    {
        <a class="as-link" asp-area="Identity" asp-page="/Account/Login">Login</a>
    }
</div>