<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VgcCollege.Web</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/VgcCollege.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark mb-3">
            .navbar a {
            color: #ffffff !important;
            }
            .navbar a:hover {
            color: #93c5fd !important;
            }
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">VgcCollege.Web</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <div class="menu-links d-flex gap-3">
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-controller="Branch" asp-action="Index">Branches</a>
                            <span>|</span>
                            <a asp-controller="Course" asp-action="Index">Courses</a>
                            <span>|</span>
                            <a asp-controller="StudentProfile" asp-action="Index">Students</a>
                            <span>|</span>
                            <a asp-controller="FacultyProfile" asp-action="Index">Faculty</a>
                            <span>|</span>
                            <a asp-controller="Admin" asp-action="Index">Admins</a>
                        }
                        @if (User.IsInRole("Faculty"))
                        {
                            <a asp-controller="Course" asp-action="Index">Courses</a>
                        }
                        @if (User.IsInRole("Student"))
                        {
                            <a asp-controller="Course" asp-action="Index">Courses</a>
                            <span>|</span>
                            <a asp-controller="Assignment" asp-action="MyResults">Assignments</a>
                            <span>|</span>
                            <a asp-controller="Exam" asp-action="MyResults">Exams</a>
                        }
                    </div>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - VgcCollege.Web - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
