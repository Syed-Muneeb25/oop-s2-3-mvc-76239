<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VgcCollege.Web</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/VgcCollege.Web.styles.css" asp-append-version="true" />
</head>
<body class="app">
    <div class="app-bg" aria-hidden="true"></div>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark app-nav">
            <div class="container-fluid px-3 px-lg-4">
                <a class="navbar-brand app-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="app-mark">VGC</span>
                    <span class="app-name">College</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse justify-content-between">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 gap-lg-2 app-navlinks">
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Branch" asp-action="Index">Branches</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Course" asp-action="Index">Courses</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="StudentProfile" asp-action="Index">Students</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="FacultyProfile" asp-action="Index">Faculty</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="Index">Admins</a></li>
                        }
                        @if (User.IsInRole("Faculty"))
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Course" asp-action="Index">Courses</a></li>
                        }
                        @if (User.IsInRole("Student"))
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Course" asp-action="Index">Courses</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Assignment" asp-action="MyResults">Assignments</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Exam" asp-action="MyResults">Exams</a></li>
                        }
                    </ul>
                    <div class="ms-lg-3">
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <div class="container-fluid px-3 px-lg-4 app-shell">
        <main role="main" class="pb-4 app-main">
            @RenderBody()
        </main>
    </div>

    <footer class="footer app-footer">
        <div class="container-fluid px-3 px-lg-4 d-flex align-items-center justify-content-between gap-3">
            <div class="app-footer-text">&copy; 2026 - VGC College</div>
            <a class="app-footer-link" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
