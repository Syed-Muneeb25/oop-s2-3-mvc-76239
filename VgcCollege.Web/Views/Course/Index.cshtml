@model IEnumerable<VgcCollege.Domain.Course>

@{
    ViewData["Title"] = "Courses";
}

<h1>Courses</h1>
<p>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create">Create New</a>
    }
</p>

<table>
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(m => m.Name)</th>
            <th>Branch</th>
            <th>Faculty</th>
            <th>@Html.DisplayNameFor(m => m.StartDate)</th>
            <th>@Html.DisplayNameFor(m => m.EndDate)</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(m => item.Name)</td>
                <td>@item.Branch?.Name</td>
                <td>@item.FacultyProfile?.Name</td>
                <td>@Html.DisplayFor(m => item.StartDate)</td>
                <td>@Html.DisplayFor(m => item.EndDate)</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a>
                    @if (User.IsInRole("Admin"))
                    {
                        <span> | </span>
                        <a asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>