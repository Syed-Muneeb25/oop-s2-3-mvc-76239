@model IEnumerable<VgcCollege.Domain.AssignmentResult>

@{
    ViewData["Title"] = "My Results";
}

<h1>My Assignment Results</h1>
<hr />

<table>
    <thead>
        <tr>
            <th>Course</th>
            <th>Assignment</th>
            <th>Score</th>
            <th>Max Score</th>
            <th>Feedback</th>
            <th>Due Date</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Assignment?.Course?.Name</td>
                <td>@item.Assignment?.Title</td>
                <td>@item.Score</td>
                <td>@item.Assignment?.MaxScore</td>
                <td>@item.Feedback</td>
                <td>@item.Assignment?.DueDate</td>
            </tr>
        }
    </tbody>
</table>